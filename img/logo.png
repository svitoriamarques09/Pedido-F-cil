l_workspace_owner_domain\":true,\"terms_url\":\"https://help.openai.com/en/articles/20001150\",\"check_paid_business_seat\":true,\"per_eligible_invite_num_credits\":2500,\"max_total_credit_amount_usd\":500,\"run_grant_sentinel_check\":true,\"exclude_usage_based_seats_from_paid_business_seat_check\":true},\"is_device_based\":false,\"passed\":false},\"2801269291\":{\"name\":\"2801269291\",\"rule_id\":\"3GogURDyenQHgosA47nZdx-3GogUPYvM5HcWYUEsZslUv\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"apps\":[\"asdk_app_693ca6ce2db08191bb52d66743c65184\",\"connector_76869538009648d5b282a4bb21c3d157\",\"asdk_app_69377d07cd9c8191a988f06f15b8c674\",\"connector_5f3c8c41a1e54ad7a76272c89e2554fa\",\"connector_692de805e3ec8191834719067174a384\",\"connector_68df33b1a2d081918778431a9cfca8ba\",\"connector_69312da8e4dc81919370cb86fd172b6c\"]},\"is_device_based\":false,\"passed\":true},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"489084288\":{\"name\":\"489084288\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"options\":[\"google\",\"apple\",\"microsoft\",\"email\",\"phone_number\"]},\"is_device_based\":true,\"passed\":false},\"3220227605\":{\"name\":\"3220227605\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"3561896342\":{\"name\":\"3561896342\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"trailblazer\":[],\"pioneer\":[],\"stratos\":[],\"seeker\":[],\"wayfinder\":[],\"maverick\":[]},\"is_device_based\":true,\"passed\":false},\"574611634\":{\"name\":\"574611634\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"connector_link_policies\":{\"connector_2128aebfecb84f64a069897515042a44\":{\"link_created_at_min\":\"2026-03-03T22:00:00Z\"}}},\"is_device_based\":false,\"passed\":false},\"112877228\":{\"name\":\"112877228\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"1007700932\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{\"mcps_prompt_override\":\"\",\"citation_output_processor\":true,\"enable_toggle_p1